{
  "name": "playwright-saucedemo",
  "version": "1.0.0",
  "description": "Playwright JS automation portfolio project on SauceDemo",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:login": "npx playwright test tests/auth/login.spec.js",
    "test:inventory": "npx playwright test tests/inventory/inventory.spec.js",
    "test:api": "npx playwright test tests/api/",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "report": "npx playwright show-report",
    "//": "=== ALLURE Report ===",
    "//clean": "Remove-Item -Recurse -Force test-results, playwright-report -ErrorAction SilentlyContinue",
    "clean": "rimraf test-results playwright-report allure-results allure-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "//allure:serve": "allure serve allure-results",
    "test:allure": "npx playwright test && npm run allure:generate && npm run allure:open",
    "//test:allure": "npx playwright test && npm run allure:serve",
    "test:login:allure": "npx playwright test tests/auth/login.spec.js && npm run allure:generate && npm run allure:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "allure-js-commons": "^3.7.1",
    "allure-playwright": "^3.7.1",
    "rimraf": "^6.1.3"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "axios": "^1.15.0",
    "dotenv": "^17.4.1"
  },
  "directories": {
    "test": "tests"
  }
}
